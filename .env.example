PORT=3000
NODE_ENV=development

# MongoDB connection string
MONGODB_URI=mongodb://objectservice:objectservice_password@mongodb:27017/objectdb

# Auth Service URL — public key is fetched once on startup for local JWT verification
AUTH_SERVICE_URL=https://auth.freischule.info

# Internal API key for microservice-to-microservice calls (X-API-Key header)
API_KEY=your-secret-api-key-here

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,https://freischule.info
